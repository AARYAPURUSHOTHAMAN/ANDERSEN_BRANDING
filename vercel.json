{
  "rewrites": [
    {
      "source": "/api-vertex/:path*",
      "destination": "/api/vertex"
    },
    {
      "source": "/api-linkfinder",
      "destination": "https://api.linkfinderai.com"
    },
    {
      "source": "/api-linkfinder/:path*",
      "destination": "https://api.linkfinderai.com/:path*"
    },
    {
      "source": "/api-getprospect/:path*",
      "destination": "https://api.getprospect.com/:path*"
    },
    {
      "source": "/api-tavily/:path*",
      "destination": "https://api.tavily.com/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
